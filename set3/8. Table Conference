import java.util.*;

public class Main {

    static long fact(int n) {
        long res = 1;

        for(int i = 2; i <= n; i++) {
            res *= i;
        }

        return res;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        long ans = 2 * fact(n - 1);

        System.out.println(ans);
    }
}
