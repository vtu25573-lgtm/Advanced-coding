import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        String binary = Integer.toBinaryString(n);
        String result = "";

        for(char c : binary.toCharArray()) {
            if(c == '0')
                result += "1";
            else
                result += "0";
        }

        System.out.println(Integer.parseInt(result, 2));
    }
}
